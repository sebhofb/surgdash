{
  "name": "surgdash",
  "version": "2.0.2",
  "description": "SURGdash - Project Management & Analytics Dashboard",
  "author": "Global Surgery Foundation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "release": "electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.gsf.surgdash",
    "productName": "SURGdash",
    "publish": [
      {
        "provider": "github",
        "owner": "sebhofb",
        "repo": "surgdash"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "sign": false
    },
    "afterSign": "scripts/notarize.js",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "html2canvas": "^1.4.1",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  }
}
